# Database
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/planmybudget

# JWT
JWT_SECRET=your-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=43200

# CORS
ALLOWED_ORIGINS=http://localhost:5173,https://planmybudget.xyz

# Redis (optional, for rate limiting)
UPSTASH_REDIS_URL=
UPSTASH_REDIS_TOKEN=

# Google OAuth
GOOGLE_CLIENT_ID=

# SMTP (optional, for email/OTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@planmybudget.app

# App
ENVIRONMENT=development
